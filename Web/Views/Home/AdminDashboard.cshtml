        function editDish(dish) {
            document.getElementById('dishFormTitle').innerText = "Chỉnh Sửa Món Ăn: " + dish.name;
            document.getElementById('dishId').value = dish.id;
            document.getElementById('dishName').value = dish.name;
            document.getElementById('dishPrice').value = dish.price;
            document.getElementById('dishBadge').value = dish.badge || '';
            document.getElementById('dishRating').value = dish.rating;
            document.getElementById('dishImageUrl').value = dish.imageUrl;
            document.getElementById('dishDescription').value = dish.description || '';
            document.getElementById('currentImageLabel').innerText = "Ảnh hiện tại: " + dish.imageUrl;
            document.getElementById('dishImageFile').value = "";
            
            document.getElementById('btnCancelEdit').style.display = "inline-block";
        }

        function cancelDishEdit() {
            document.getElementById('dishFormTitle').innerText = "Thêm Món Ăn Mới";
            document.getElementById('dishId').value = "";
            document.getElementById('dishName').value = "";
            document.getElementById('dishPrice').value = "";
            document.getElementById('dishBadge').value = "";
            document.getElementById('dishRating').value = "5.0";
            document.getElementById('dishImageUrl').value = "";
            document.getElementById('dishDescription').value = "";
            document.getElementById('currentImageLabel').innerText = "";
            document.getElementById('dishImageFile').value = "";
            
            document.getElementById('btnCancelEdit').style.display = "none";
        }

        async function submitDish() {
            const idVal = document.getElementById('dishId').value;
            const name = document.getElementById('dishName').value.trim();
            const price = document.getElementById('dishPrice').value.trim();
            const badge = document.getElementById('dishBadge').value.trim();
            const rating = parseFloat(document.getElementById('dishRating').value);
            const imageUrl = document.getElementById('dishImageUrl').value.trim();
            const description = document.getElementById('dishDescription').value.trim();
            const fileInput = document.getElementById('dishImageFile');

            let uploadedFileName = imageUrl;

            // Nếu người dùng chọn file ảnh mới, tiến hành upload lên server trước
            if (fileInput.files.length > 0) {
                const formData = new FormData();
                formData.append("file", fileInput.files[0]);

                const submitBtn = document.getElementById('btnSubmitDish');
                const cancelBtn = document.getElementById('btnCancelEdit');
                
                submitBtn.disabled = true;
                submitBtn.innerText = "Đang tải ảnh...";
                if (cancelBtn) cancelBtn.style.display = "none";

                try {
                    const uploadResponse = await fetch('/Home/UploadDishImage', {
                        method: 'POST',
                        body: formData
                    });
                    const uploadResult = await uploadResponse.json();
                    if (uploadResult.success) {
                        uploadedFileName = uploadResult.fileName;
                    } else {
                        alert("Lỗi tải ảnh lên: " + uploadResult.message);
                        submitBtn.disabled = false;
                        submitBtn.innerText = "Lưu Món Ăn";
                        if (cancelBtn && idVal) cancelBtn.style.display = "inline-block";
                        return;
                    }
                } catch (err) {
                    alert("Lỗi kết nối khi tải ảnh lên.");
                    submitBtn.disabled = false;
                    submitBtn.innerText = "Lưu Món Ăn";
                    if (cancelBtn && idVal) cancelBtn.style.display = "inline-block";
                    return;
                }
            }

            if (!name || !price || !uploadedFileName) {
                alert("Vui lòng nhập đầy đủ: Tên món ăn, Giá và chọn file Hình ảnh");
                return;
            }

            const dishData = {
                Name: name,
                Price: price,
                Badge: badge,
                Rating: rating,
                ImageUrl: uploadedFileName,
                Description: description
            };

            let endpoint = '/Home/AddDish';
            if (idVal) {
                dishData.Id = parseInt(idVal);
                endpoint = '/Home/UpdateDish';
            }

            const response = await fetch(endpoint, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(dishData)
            });

            const data = await response.json();
            if (data.success) {
                location.reload();
            } else {
                alert("Lỗi: " + data.message);
                const submitBtn = document.getElementById('btnSubmitDish');
                submitBtn.disabled = false;
                submitBtn.innerText = "Lưu Món Ăn";
            }
        }

        async function deleteDish(id) {
            if (!confirm("Bạn có chắc chắn muốn xóa món ăn này khỏi thực đơn?")) return;
            const response = await fetch('/Home/DeleteDish', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ id: id })
            });

            const data = await response.json();
            if (data.success) {
                location.reload();
            } else {
                alert("Lỗi: " + data.message);
            }
        }
    </script>
