@{
    ViewData["Title"] = "Trang Chủ";
}

<!-- Phần Hero phong cách Cinematic điện ảnh -->
<section class="hero-section">
    <img src="~/images/hero.png" alt="Miyabi Hero Background" class="hero-bg" />
    <div class="hero-overlay"></div>
    <div class="hero-content">

        <div class="hero-kanji">雅</div>
        <h1 class="hero-title">
            Trải Nghiệm Tinh Hoa
            <span>ẨM THỰC NHẬT BẢN THƯỢNG HẠNG</span>
        </h1>
        <p class="hero-subtitle">
            Nơi giao thoa giữa nghệ thuật ẩm thực Omakase Kyoto cổ điển và tinh thần tối giản đương đại. 
            Mỗi món ăn là một tác phẩm nghệ thuật đánh thức mọi giác quan.
        </p>
        <div class="hero-buttons">
            <a href="#reservation" class="btn-premium btn-premium-primary">Đặt Bàn Ngay</a>
            <a href="#menu" class="btn-premium btn-premium-secondary">Khám Phá Thực Đơn</a>
        </div>
    </div>
    <a href="#about" class="scroll-indicator">
        <span>Cuộn xuống</span>
        <div class="scroll-line"></div>
    </a>
</section>

<!-- Phần Giới thiệu - Về chúng tôi (About Us) -->
<section id="about" class="section-wrapper about-section reveal">
    <div class="about-container">
        <!-- Khối nội dung giới thiệu -->
        <div class="about-text">
            <div class="about-story">
                <span class="section-subtitle-jp">雅の歴史</span>
                <h2 class="section-title-en mb-4" style="text-align: left; padding-bottom: 0.8rem; display: block; width: 100%;">Về Chúng Tôi</h2>
                <h3 class="mb-3" style="color: var(--color-gold);">Khởi nguồn từ Kyoto cổ kính</h3>
                <p>
                    Miyabi (雅 - Nhã) được thành lập vào năm 1998 tại một con ngõ nhỏ yên tĩnh thuộc quận Gion, Kyoto. 
                    Nơi đây khởi đầu như một quán ăn gia đình chuyên biệt phục vụ Omakase, giữ gìn triết lý ẩm thực truyền thống 
                    kết hợp với sự giản dị, tôn trọng tự nhiên của Thiền học Nhật Bản.
                </p>
                <p>
                    Trải qua hơn hai thập kỷ gìn giữ và phát triển, Miyabi đã mang tinh hoa Omakase vượt khỏi biên giới Nhật Bản. 
                    Năm 2024, Miyabi chính thức mở cửa chi nhánh Fine Dining độc bản đầu tiên tại TP. Hồ Chí Minh, mang theo nguyên bản 
                    tinh thần ẩm thực truyền thống kết hợp cùng nghệ thuật phục vụ hiếu khách tinh tế Omotenashi.
                </p>
            </div>
            
            <div class="about-achievements">
                <h3 class="mb-3" style="color: var(--color-gold);">Thành tựu đạt được</h3>
                <div class="achievements-grid">
                    <!-- Thành tựu 1 -->
                    <div class="achievement-card">
                        <div class="ach-icon">
                            <svg viewBox="0 0 24 24"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
                        </div>
                        <h4 class="ach-title">1 Sao Michelin</h4>
                        <p class="ach-desc">Khẳng định chất lượng ẩm thực đẳng cấp thế giới.</p>
                    </div>

                    <!-- Thành tựu 2 -->
                    <div class="achievement-card">
                        <div class="ach-icon">
                            <!-- Trohpy Icon -->
                            <svg viewBox="0 0 24 24"><path d="M18 2H6c-1.1 0-2 .9-2 2v3c0 2.24 1.81 4.07 4.05 4.11C8.75 12.39 10.23 13.5 12 13.9V17H9c-.55 0-1 .45-1 1v2c0 .55.45 1 1 1h6c.55 0 1-.45 1-1v-2c0-.55-.45-1-1-1h-3v-3.1c1.77-.4 3.25-1.51 3.95-2.79C18.19 11.07 20 9.24 20 7V4c0-1.1-.9-2-2-2zM6 7V4h2v3c0 .82-.18 1.58-.49 2.27C6.61 8.81 6 8 6 7zm11.49 2.27C17.18 8.58 17 7.82 17 7V4h2v3c0 .8-.61 1.61-1.51 2.27z"/></svg>
                        </div>
                        <h4 class="ach-title">Asia's 50 Best</h4>
                        <p class="ach-desc">Vinh danh trong Top nhà hàng xuất sắc tại Châu Á.</p>
                    </div>

                    <!-- Thành tựu 3 -->
                    <div class="achievement-card">
                        <div class="ach-icon">
                            <!-- Design Award Icon -->
                            <svg viewBox="0 0 24 24"><path d="M12 3L2 12h3v8h6v-6h2v6h6v-8h3L12 3z"/></svg>
                        </div>
                        <h4 class="ach-title">Thiết kế Zen</h4>
                        <p class="ach-desc">Giải thưởng kiến trúc không gian Thiền đương đại.</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Khung ảnh Kyoto cổ kính -->
        <div class="about-img-frame">
            <div class="about-img-wrapper">
                <img src="~/images/gion_street.png" alt="Kyoto Gion Street" class="about-img" />
                <div class="about-img-overlay"></div>
            </div>
        </div>
    </div>
</section>

<!-- Phần Danh sách Món ăn Nổi bật -->
<section id="menu" class="section-wrapper reveal">
    <div class="section-header">
        <span class="section-subtitle-jp">お勧め料理</span>
        <h2 class="section-title-en">Thực Đơn Tinh Tuyển</h2>
    </div>
    
    <div class="dishes-grid">
        @if (ViewBag.Dishes != null)
        {
            foreach (var dish in (List<Web.Models.Dish>)ViewBag.Dishes)
            {
                <div class="dish-card">
                    @if (!string.IsNullOrEmpty(dish.Badge))
                    {
                        <div class="dish-badge">@dish.Badge</div>
                    }
                    <div class="dish-image-wrapper">
                        <img src="@(dish.ImageUrl.StartsWith("http") ? dish.ImageUrl : Url.Content("~/images/" + dish.ImageUrl))" alt="@dish.Name" class="dish-image" />
                        <div class="dish-image-overlay"></div>
                    </div>
                    <div class="dish-info">
                        <div class="dish-header">
                            <h3 class="dish-title">@dish.Name</h3>
                            <span class="dish-price">@dish.Price</span>
                        </div>
                        <p class="dish-desc">
                            @dish.Description
                        </p>
                        <div class="dish-meta">
                            <div class="dish-rating">
                                @for (int i = 0; i < 5; i++)
                                {
                                    <svg viewBox="0 0 24 24" style="fill: @(i < Math.Round(dish.Rating) ? "var(--color-gold)" : "rgba(255,255,255,0.1)"); width: 14px; height: 14px;"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
                                }
                                <span>(@dish.Rating.ToString("0.0"))</span>
                            </div>
                            <button class="dish-order-btn" onclick="location.href='#reservation'">
                                Đặt bàn
                                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                            </button>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</section>

<!-- Phần Không gian Kyoto Fine Dining -->
<section id="atmosphere" class="atmosphere-section">
    <img src="~/images/interior.png" alt="Kyoto Zen Atmosphere" class="atmosphere-bg" />
    <div class="atmosphere-overlay"></div>
    <div class="atmosphere-content reveal">
        <div class="atmosphere-text">
            <div class="atmosphere-kanji-huge">禅</div>
            <span class="section-subtitle-jp">お店 của không gian</span>
            <h2 class="atmosphere-title">Không Gian Thiền & <span>Nghệ Thuật Kyoto</span></h2>
            <p class="atmosphere-desc text-white">
                Miyabi được lấy cảm hứng từ kiến trúc gỗ Hinoki truyền thống của Cố đô Kyoto. 
                Sự hòa trộn tinh tế giữa ánh sáng đèn lồng ấm áp và không gian yên bình giúp thực khách 
                hoàn toàn thả lỏng tâm trí để thưởng thức tinh hoa ẩm thực.
            </p>
        </div>
        
        <!-- Lưới 3 khu vực ăn uống -->
        <div class="atmosphere-grid">
            <!-- Khu vực 1 -->
            <div class="atmosphere-card">
                <div class="atm-card-img-wrapper">
                    <img src="~/images/sushi_counter.png" alt="Quầy Sushi Gỗ Hinoki" class="atm-card-img" />
                </div>
                <div class="atm-card-info">
                    <h3 class="atm-card-title">Quầy Bar Omakase</h3>
                    <p class="atm-card-desc">
                        Nơi tương tác trực tiếp cùng Bếp trưởng, chiêm ngưỡng nghệ thuật chế biến tinh xảo trên bàn gỗ Hinoki nguyên khối hàng trăm năm tuổi.
                    </p>
                </div>
            </div>

            <!-- Khu vực 2 -->
            <div class="atmosphere-card">
                <div class="atm-card-img-wrapper">
                    <img src="~/images/vip_tatami.png" alt="Phòng VIP Tatami" class="atm-card-img" />
                </div>
                <div class="atm-card-info">
                    <h3 class="atm-card-title">Phòng VIP Tatami</h3>
                    <p class="atm-card-desc">
                        Không gian riêng tư khép kín mang đậm phong cách trà đạo Nhật Bản, chiếu tatami êm ái, thích hợp tiếp đối tác hoặc họp mặt gia đình.
                    </p>
                </div>
            </div>

            <!-- Khu vực 3 -->
            <div class="atmosphere-card">
                <div class="atm-card-img-wrapper">
                    <img src="~/images/dining_koi.png" alt="Sảnh Chính Hồ Koi" class="atm-card-img" />
                </div>
                <div class="atm-card-info">
                    <h3 class="atm-card-title">Sảnh Chính Hồ Koi</h3>
                    <p class="atm-card-desc">
                        Không gian ăn uống rộng rãi khoáng đạt bên cửa kính lớn, phóng tầm mắt ra hồ cá Koi lung linh sắc màu và khu vườn thiền thanh tịnh.
                    </p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Phần Đặt bàn hiệu ứng kính mờ (Glassmorphism) -->
<section id="reservation" class="section-wrapper reservation-section reveal">
    <div class="reservation-container">
        <!-- Chi tiết thông tin đặt bàn -->
        <div class="reserve-details">
            <span class="section-subtitle-jp">席を予約する</span>
            <h2 class="reserve-tagline">Kiến Tạo <span>Trải Nghiệm Riêng</span> Cho Đêm Nay</h2>
            <p>
                Do triết lý tập trung phục vụ tỉ mỉ từng chi tiết cho từng vị khách, số lượng ghế tại quầy Omakase của chúng tôi giới hạn chỉ 12 vị trí mỗi tối. 
                Quý khách vui lòng đặt bàn trước để Miyabi có thể chuẩn bị nguyên liệu hoàn hảo nhất.
            </p>
            
            <div class="reserve-info-cards">
                <div class="reserve-info-card">
                    <h4>Quầy Omakase Bar</h4>
                    <p>Giới hạn 12 khách - Phục vụ trực tiếp từ Bếp trưởng.</p>
                </div>
                <div class="reserve-info-card">
                    <h4>Phòng Private VIP</h4>
                    <p>Yêu cầu đặt trước 24h - Phù hợp từ 4 đến 10 khách.</p>
                </div>
                <div class="reserve-info-card">
                    <h4>Hotline hỗ trợ trực tiếp</h4>
                    <p>+84 90 123 4567 (Hỗ trợ 24/7)</p>
                </div>
            </div>
        </div>

        <!-- Biểu mẫu đặt bàn hiệu ứng kính mờ -->
        <div class="booking-glass-panel">
            @if (User.Identity.IsAuthenticated)
            {
                <div class="booking-form-header">
                    <h3>Đặt Bàn</h3>
                    <p class="text-white opacity-75">MIYABI LUXURY FINE DINING</p>
                </div>
                
                <form id="bookingForm" class="booking-form">
                    <!-- Các trường nhập Tên và Số điện thoại -->
                    <div class="form-group-custom">
                        <label class="form-label-custom" for="GuestName">Họ và Tên</label>
                        <input type="text" id="GuestName" placeholder="Tên của quý khách..." class="form-input-custom" value="@User.Identity.Name" required />
                    </div>
                    
                    <div class="form-group-custom">
                        <label class="form-label-custom" for="GuestPhone">Số Điện Thoại</label>
                        <input type="tel" id="GuestPhone" placeholder="Số điện thoại liên lạc..." class="form-input-custom" required />
                    </div>

                    <!-- Trình chọn Ngày và số lượng Khách -->
                    <div class="form-row-custom">
                        <div class="form-group-custom">
                            <label class="form-label-custom" for="BookingDate">Chọn Ngày</label>
                            <input type="date" id="BookingDate" class="form-input-custom" required />
                        </div>
                        
                        <div class="form-group-custom guest-picker-container">
                            <label class="form-label-custom">Số Khách</label>
                            <div class="form-input-custom custom-select-trigger">
                                Chọn số khách
                                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
                            </div>
                            <input type="hidden" id="GuestCount" required />
                            <div class="dropdown-menu-custom">
                                <div class="dropdown-item-custom" data-value="1">1 khách</div>
                                <div class="dropdown-item-custom" data-value="2">2 khách</div>
                                <div class="dropdown-item-custom" data-value="3">3 khách</div>
                                <div class="dropdown-item-custom" data-value="4">4 khách</div>
                                <div class="dropdown-item-custom" data-value="5-8">5 - 8 khách</div>
                                <div class="dropdown-item-custom" data-value="9+">Trên 8 khách</div>
                            </div>
                        </div>
                    </div>

                    <!-- Trình chọn Khu vực phục vụ tùy chỉnh -->
                    <div class="form-group-custom">
                        <label class="form-label-custom">Khu Vực Phục Vụ</label>
                        <div class="form-input-custom custom-select-trigger">
                            Chọn khu vực...
                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
                        </div>
                        <input type="hidden" id="SeatingPreference" required />
                        <div class="dropdown-menu-custom">
                            <div class="dropdown-item-custom" data-value="Omakase Counter">Quầy Sushi Gỗ Hinoki (Omakase Bar - Tối đa 12 khách)</div>
                            <div class="dropdown-item-custom" data-value="Small VIP Room">Phòng VIP Tatami Nhỏ (Từ 4 - 6 khách)</div>
                            <div class="dropdown-item-custom" data-value="Large VIP Room">Phòng VIP Tatami Lớn (Từ 8 - 12 khách)</div>
                            <div class="dropdown-item-custom" data-value="Main Dining Room">Sảnh Ăn Chung Hồ Koi (Bàn 2 - 8 khách)</div>
                        </div>
                    </div>

                    <!-- Trình chọn Khung giờ phục vụ (Session) -->
                    <div class="form-group-custom">
                        <label class="form-label-custom">Giờ Phục Vụ (Session)</label>
                        <input type="hidden" id="SelectedTime" required />
                        <div class="session-buttons">
                            <div class="session-btn" data-time="11:30">Trưa 11:30</div>
                            <div class="session-btn" data-time="17:30">Tối I (17:30)</div>
                            <div class="session-btn" data-time="19:30">Tối II (19:30)</div>
                        </div>
                    </div>

                    <!-- Sơ đồ vị trí bàn ghế tương tác động -->
                    <input type="hidden" id="SelectedTableNumber" required />

                    <style>
                        .seating-area-omakase {
                            display: flex;
                            flex-direction: column;
                            align-items: center;
                            gap: 20px;
                            width: 100%;
                            max-width: 450px;
                        }
                        .omakase-counter-line {
                            width: 80%;
                            height: 12px;
                            background: linear-gradient(90deg, #c8a96b, #8c6b30);
                            border-radius: 6px;
                            position: relative;
                            box-shadow: 0 0 15px rgba(200, 169, 107, 0.4);
                            margin-bottom: 5px;
                        }
                        .omakase-counter-label {
                            position: absolute;
                            top: -22px;
                            left: 50%;
                            transform: translateX(-50%);
                            font-size: 0.75rem;
                            color: var(--color-gold);
                            letter-spacing: 0.2em;
                            text-transform: uppercase;
                            white-space: nowrap;
                        }
                        .omakase-seats-grid {
                            display: grid;
                            grid-template-columns: repeat(6, 1fr);
                            gap: 12px;
                            width: 100%;
                        }
                        .seat-item {
                            display: flex;
                            flex-direction: column;
                            align-items: center;
                            gap: 5px;
                            cursor: pointer;
                            padding: 8px;
                            border-radius: 6px;
                            border: 1px solid rgba(255, 255, 255, 0.05);
                            background: rgba(255, 255, 255, 0.02);
                            transition: 0.25s ease;
                        }
                        .seat-item:hover:not(.occupied) {
                            background: rgba(200, 169, 107, 0.15);
                            border-color: var(--color-gold);
                            transform: translateY(-2px);
                        }
                        .seat-icon {
                            width: 20px;
                            height: 20px;
                            border-radius: 50%;
                            background: #444;
                            border: 2px solid #666;
                            transition: 0.25s ease;
                        }
                        .seat-item.vacant .seat-icon {
                            background: #554a32;
                            border-color: var(--color-gold);
                        }
                        .seat-item.selected .seat-icon {
                            background: var(--color-gold) !important;
                            border-color: #fff !important;
                            box-shadow: 0 0 12px var(--color-gold);
                        }
                        .seat-item.occupied {
                            cursor: not-allowed;
                            opacity: 0.4;
                        }
                        .seat-item.occupied .seat-icon {
                            background: #802a2a !important;
                            border-color: #ff4d4d !important;
                        }
                        .seat-label {
                            font-size: 0.65rem;
                            color: rgba(255,255,255,0.7);
                        }

                        /* VIP Rooms Style */
                        .seating-area-vip {
                            display: flex;
                            gap: 20px;
                            width: 100%;
                            max-width: 500px;
                            justify-content: center;
                        }
                        .vip-room-card {
                            flex: 1;
                            aspect-ratio: 1.3;
                            max-width: 180px;
                            border: 2px dashed rgba(200, 169, 107, 0.3);
                            border-radius: 10px;
                            display: flex;
                            flex-direction: column;
                            justify-content: center;
                            align-items: center;
                            padding: 12px;
                            background: rgba(255, 255, 255, 0.01);
                            cursor: pointer;
                            transition: 0.3s ease;
                            position: relative;
                        }
                        .vip-room-card:hover:not(.occupied) {
                            border-color: var(--color-gold);
                            background: rgba(200, 169, 107, 0.08);
                            transform: translateY(-3px);
                        }
                        .vip-room-card.selected {
                            border-color: var(--color-gold) !important;
                            border-style: solid !important;
                            background: rgba(200, 169, 107, 0.2) !important;
                            box-shadow: 0 0 18px rgba(200, 169, 107, 0.3);
                        }
                        .vip-room-card.occupied {
                            cursor: not-allowed;
                            border-color: #ff4d4d !important;
                            background: rgba(128, 42, 42, 0.2) !important;
                            opacity: 0.5;
                        }
                        .vip-room-kanji {
                            font-family: var(--font-jp);
                            font-size: 1.8rem;
                            color: rgba(255, 255, 255, 0.15);
                            margin-bottom: 5px;
                            transition: 0.3s;
                        }
                        .vip-room-card.selected .vip-room-kanji {
                            color: var(--color-gold);
                        }
                        .vip-room-name {
                            font-family: var(--font-serif);
                            font-size: 0.9rem;
                            color: var(--color-gold);
                            font-weight: bold;
                        }
                        .vip-room-capacity {
                            font-size: 0.7rem;
                            color: rgba(255, 255, 255, 0.5);
                            margin-top: 3px;
                        }

                        /* Main Dining Style */
                        .seating-area-dining {
                            display: grid;
                            grid-template-columns: repeat(3, 1fr);
                            gap: 12px;
                            width: 100%;
                            max-width: 500px;
                        }
                        .dining-table-card {
                            border: 1px solid rgba(255, 255, 255, 0.08);
                            border-radius: 8px;
                            padding: 10px;
                            background: rgba(255, 255, 255, 0.02);
                            display: flex;
                            flex-direction: column;
                            align-items: center;
                            justify-content: center;
                            cursor: pointer;
                            transition: 0.25s ease;
                            position: relative;
                        }
                        .dining-table-card:hover:not(.occupied) {
                            border-color: var(--color-gold);
                            background: rgba(200, 169, 107, 0.15);
                            transform: translateY(-2px);
                        }
                        .dining-table-card.selected {
                            border-color: var(--color-gold) !important;
                            background: rgba(200, 169, 107, 0.25) !important;
                            box-shadow: 0 0 15px rgba(200, 169, 107, 0.3);
                        }
                        .dining-table-card.occupied {
                            cursor: not-allowed;
                            border-color: #ff4d4d !important;
                            background: rgba(128, 42, 42, 0.15) !important;
                            opacity: 0.4;
                        }
                        .table-visual {
                            width: 28px;
                            height: 18px;
                            background: #555;
                            border-radius: 4px;
